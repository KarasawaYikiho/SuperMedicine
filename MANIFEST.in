exclude .gitignore
include permission/default_policy.yaml
include THIRD_PARTY_NOTICES.md
prune .github
prune .supermedicine/checkpoints
prune .supermedicine/experiments
prune .supermedicine/logs
prune .supermedicine/rag
prune .supermedicine/sessions
prune .pytest_cache
prune .pytest-tmp
prune .pytest_tmp
prune .ruff_cache
prune .mypy_cache
prune build
prune dist
prune Docs
prune docs
prune Architecture
global-exclude *.py[cod]
global-exclude __pycache__
global-exclude *.log
