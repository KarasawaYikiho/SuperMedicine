/* SuperMedicine TUI Stylesheet
   Variables ($primary, $surface, $background, etc.) are auto-generated
   by Textual from the Theme registered in the app module.
*/

Screen {
    layout: vertical;
    background: $background;
    color: $foreground;
}

#app-body {
    height: 1fr;
    width: 100%;
    min-height: 0;
    overflow: hidden;
}

/* Sidebar */
#sidebar {
    width: 25;
    min-width: 20;
    height: 100%;
    min-height: 0;
    overflow-y: auto;
    background: $surface;
    border-right: solid $border;
}

#sidebar-title {
    height: 1;
    padding: 0 1;
    text-style: bold;
    color: $accent;
    content-align: left middle;
}

#menu-button {
    height: 1;
    padding: 0 1;
    background: $surface;
    color: $accent;
    text-style: bold;
    content-align: left middle;
}

#menu-button:hover {
    background: $primary 18%;
}

.menu-affordance {
    color: $accent;
}

#sidebar-subtitle {
    height: 1;
    padding: 0 1;
    color: $text-muted;
    content-align: left middle;
    border-bottom: solid $border;
}

.shell-title {
    background: $surface;
}

.shell-subtitle {
    text-style: none;
}

#nav-list {
    height: 1fr;
    background: $surface;
}

#nav-list > NavItem {
    padding: 0 1;
    height: 2;
    color: $foreground;
}

#nav-list > NavItem:hover {
    background: $primary 12%;
}

#nav-list > NavItem.-active {
    background: $primary 18%;
    text-style: bold;
    border-left: solid $accent;
    color: $foreground;
}

#tui-menu-panel {
    width: 42;
    height: auto;
    max-height: 85%;
    margin: 1 0 0 1;
    padding: 0 1;
    background: $surface;
    border: solid $border;
}

#tui-menu-title {
    height: 3;
    padding: 0 1;
    content-align: left middle;
}

.tui-menu-list {
    height: auto;
    max-height: 18;
    background: $surface;
}

.tui-menu-list > MenuOption {
    height: 2;
    padding: 0 1;
}

.tui-menu-list > MenuOption:hover,
.tui-menu-list > MenuOption.-active {
    background: $primary 18%;
    text-style: bold;
}

/* Main Area */
#main-area {
    width: 1fr;
    height: 100%;
    min-height: 0;
    overflow-y: auto;
    layout: vertical;
}

#view-title {
    height: 1;
    width: 100%;
    padding: 0 1;
    background: $surface;
    color: $foreground;
    text-style: bold;
    content-align: left middle;
    border-bottom: solid $border;
}

.view-heading {
    color: $accent;
}

#content-pane {
    height: 1fr;
    width: 100%;
    min-height: 0;
    overflow-y: auto;
    padding: 1 1;
    background: $background;
}

/* Input Bar */
#input-bar {
    min-height: 3;
    height: auto;
    width: 100%;
    background: $surface;
    border-top: solid $border;
    padding: 0 1;
}

#prompt-prefix {
    width: 3;
    height: auto;
    content-align: center middle;
    text-style: bold;
    color: $accent;
}

#prompt-input {
    width: 1fr;
    height: auto;
    border: solid $border;
    background: $background;
    overflow-x: hidden;
}

#prompt-input:focus {
    border: solid $accent;
}

/* Status Bar */
#status-bar {
    height: 1;
    width: 100%;
    background: $surface;
    border-top: solid $border;
    color: $text-muted;
}

#status-left {
    width: 1fr;
    content-align: left middle;
}

#status-center {
    width: 1fr;
    content-align: center middle;
}

#status-right {
    width: 1fr;
    content-align: right middle;
}

/* Chat View */
#chat-dialog {
    height: 1fr;
    width: 100%;
    min-width: 0;
    layout: vertical;
    layers: base overlay;
}

#chat-output {
    height: 1fr;
    width: 100%;
    min-width: 0;
    overflow-y: auto;
    padding: 0 1;
    border: solid $border;
    background: $background;
}

#chat-output:focus {
    border: solid $accent;
}

#thinking-indicator {
    dock: bottom;
    align: right bottom;
    layer: overlay;
    width: auto;
    height: auto;
    margin: 0 2 1 0;
    padding: 0 1;
    background: $surface;
    border: solid $border;
    visibility: hidden;
}

#processing-indicator {
    align: left middle;
    width: auto;
    height: auto;
    padding: 0 0 0 4;
    visibility: hidden;
}

/* Dashboard */
.dashboard-stat {
    height: 1fr;
    min-height: 5;
    padding: 0 2;
}

#dashboard-summary {
    height: auto;
    padding: 0 2 1 2;
    color: $text-muted;
}

#dashboard-advice {
    height: auto;
    padding: 1 2;
    border: solid $border;
    background: $surface;
}

/* Tables */
#workspace-table,
#dashboard-table,
#paper-table,
#exp-table,
#tool-table,
#self-evolution-files-table,
#llm-table,
#dialog-table,
#log-table {
    height: 1fr;
    min-height: 5;
    border: solid $border;
}

#log-auto-follow {
    min-width: 14;
}

.hint {
    height: auto;
    color: $text-muted;
    padding: 0 1;
}

DataTable:focus {
    border: solid $accent;
}

/* Experiment page - prevent focus enlargement */
#experiment-protocol-table {
    height: auto;
    max-height: 12;
    overflow-y: auto;
}

#experiment-protocol-table:focus {
    height: auto;
    max-height: 12;
    overflow-y: auto;
}

#experiment-input-table {
    height: auto;
    max-height: 8;
    overflow-y: auto;
}

#experiment-input-table:focus {
    height: auto;
    max-height: 8;
    overflow-y: auto;
}

#experiment-data-input {
    height: auto;
    max-height: 10;
    overflow-y: auto;
    border: solid $border;
}

#experiment-data-input:focus {
    height: auto;
    max-height: 10;
    overflow-y: auto;
    border: solid $accent;
}

/* Permission page - prevent focus enlargement */
#permission-roots-table {
    height: auto;
    max-height: 8;
    overflow-y: auto;
}

#permission-roots-table:focus {
    height: auto;
    max-height: 8;
    overflow-y: auto;
}

Input,
Select {
    height: auto;
    min-width: 12;
}

.form-row {
    height: auto;
    min-height: 3;
    margin: 0 0 1 0;
}

#llm-status {
    height: auto;
    padding: 1 0;
}

#workspace-status,
#paper-status,
#exp-status,
#tool-status,
#self-evolution-status,
#self-evolution-preview-content,
#self-evolution-audit-result,
#llm-status,
#dialog-status,
#log-status,
#log-detail {
    height: auto;
    min-height: 1;
    padding: 0 1;
    color: $text-muted;
    border-left: solid $border;
    background: $surface;
}

#log-detail {
    max-height: 12;
    overflow-y: auto;
    border: solid $border;
    margin: 1 0 0 0;
}

#self-evolution-preview-content {
    max-height: 16;
    overflow-y: auto;
    border: solid $border;
    margin: 1 0 0 0;
}

#self-evolution-audit-result {
    color: $accent;
}

.status-info {
    color: $text-muted;
    border-left: solid $border;
}

.status-success {
    color: $success;
    border-left: solid $success;
}

.status-warning {
    color: $warning;
    border-left: solid $warning;
}

.status-error {
    color: $error;
    border-left: solid $error;
    text-style: bold;
}

#llm-secret-hint {
    color: $text-muted;
    padding: 0 0 1 0;
}

#llm-current {
    height: auto;
    padding: 0 1 1 1;
    color: $accent;
}

#llm-form {
    height: auto;
    border: solid $border;
    padding: 1;
}

/* Buttons */
.btn {
    margin: 0 1;
    min-width: 8;
    height: 3;
}

.btn:focus {
    border: solid $accent;
}

.btn:hover {
    text-style: bold;
}

.btn-primary {
    background: $primary 35%;
    color: $foreground;
}

.btn-primary:hover {
    background: $primary 45%;
}

.btn-danger {
    background: $error 45%;
    color: $foreground;
}

.btn-danger:hover {
    background: $error 55%;
}

.btn-secondary {
    background: $surface;
    border: solid $border;
}

.btn-secondary:hover {
    background: $primary 12%;
}

/* Section Titles */
.section-title {
    text-style: bold;
    margin: 0 0 1 0;
    padding: 0 1;
    color: $accent;
    background: $surface;
    border-left: solid $accent;
}

/* Maximized View */
.-maximized {
    height: 1fr;
    border: solid $accent;
    background: $background;
}
