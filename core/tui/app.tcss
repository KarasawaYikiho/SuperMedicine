/* Custom Color Scheme — Dark medical theme inspired by OpenCode TUI */
:root {
    $primary: #0078D4;
    $primary-lighten-1: #2899EA;
    $primary-darken-1: #005A9E;
    $surface: #1E1E2E;
    $background: #11111B;
    $panel: #181825;
    $text: #CDD6F4;
    $text-muted: #A6ADC8;
    $accent: #89B4FA;
    $success: #A6E3A1;
    $warning: #F9E2AF;
    $error: #F38BA8;
    $border: #313244;
}

/* SuperMedicine TUI Stylesheet */

Screen {
    layout: vertical;
    background: $background;
}

Header {
    background: $primary;
    color: $text;
    text-style: bold;
}

Footer {
    background: $surface;
    color: $text-muted;
}

#app-body {
    height: 1fr;
    width: 100%;
    min-height: 8;
}

/* Sidebar */
#sidebar {
    width: 24;
    min-width: 20;
    height: 100%;
    background: $surface;
    border-right: heavy $primary;
}

#sidebar-title {
    height: 3;
    padding: 0 1;
    text-style: bold;
    color: $primary;
    content-align: center middle;
}

#sidebar-subtitle {
    height: 2;
    padding: 0 1;
    color: $text-muted;
    content-align: center middle;
}

#nav-list {
    height: 1fr;
    background: $surface;
}

#nav-list > NavItem {
    padding: 0 1;
    height: 2;
}

#nav-list > NavItem:hover {
    background: $primary 20%;
}

#nav-list > NavItem.-active {
    background: $primary 40%;
    text-style: bold;
    border-left: heavy $accent;
}

#sidebar-shortcuts {
    height: 3;
    padding: 0 1;
    color: $text-muted;
    border-top: tall $primary 40%;
}

/* Main Area */
#main-area {
    width: 1fr;
    height: 100%;
    layout: vertical;
}

#view-title {
    height: 3;
    width: 100%;
    padding: 0 2;
    background: $primary 25%;
    color: $text;
    text-style: bold;
    content-align: left middle;
    border-bottom: tall $primary 50%;
}

#content-pane {
    height: 1fr;
    width: 100%;
    overflow-y: auto;
    padding: 1 1;
}

/* Input Bar */
#input-bar {
    min-height: 3;
    height: auto;
    width: 100%;
    background: $surface;
    border-top: heavy $primary;
    padding: 0 1;
}

#prompt-prefix {
    width: 4;
    height: auto;
    content-align: center middle;
    text-style: bold;
    color: $primary;
}

#prompt-input {
    width: 1fr;
    height: auto;
    border: wide $primary 40%;
}

#prompt-input:focus {
    border: wide $accent;
}

/* Status Bar */
#status-bar {
    height: 1;
    width: 100%;
    background: $primary 15%;
    border-top: tall $primary 50%;
    color: $text-muted;
}

#status-left {
    width: 1fr;
    content-align: left middle;
}

#status-center {
    width: 1fr;
    content-align: center middle;
}

#status-right {
    width: 1fr;
    content-align: right middle;
}

/* Chat View */
#chat-output {
    height: 1fr;
    width: 100%;
    overflow-y: auto;
    padding: 0 1;
    border: round $primary 30%;
    background: $surface;
}

/* Dashboard */
.dashboard-stat {
    height: 1fr;
    min-height: 5;
    padding: 0 2;
}

#dashboard-summary {
    height: auto;
    padding: 0 2 1 2;
    color: $text-muted;
}

#dashboard-advice {
    height: auto;
    padding: 1 2;
    border: round $primary 40%;
    background: $primary 10%;
}

/* Tables */
#workspace-table,
#dashboard-table,
#paper-table,
#exp-table,
#tool-table,
#llm-table,
#dialog-table {
    height: 1fr;
    min-height: 5;
    border: round $primary 30%;
}

DataTable:focus {
    border: round $accent;
}

Input,
Select {
    height: auto;
    min-width: 12;
}

.form-row {
    height: auto;
    min-height: 3;
    margin: 0 0 1 0;
}

#llm-status {
    height: auto;
    padding: 1 0;
}

#workspace-status,
#paper-status,
#exp-status,
#tool-status,
#llm-status,
#dialog-status {
    height: auto;
    min-height: 1;
    padding: 0 1;
    color: $text-muted;
    border-left: tall $primary 40%;
}

.status-info {
    color: $text-muted;
    border-left: tall $primary;
}

.status-success {
    color: $success;
    border-left: tall $success;
}

.status-warning {
    color: $warning;
    border-left: tall $warning;
}

.status-error {
    color: $error;
    border-left: tall $error;
    text-style: bold;
}

#llm-secret-hint {
    color: $text-muted;
    padding: 0 0 1 0;
}

#llm-current {
    height: auto;
    padding: 0 1 1 1;
    color: $accent;
}

#llm-form {
    height: auto;
    border: round $primary 30%;
    padding: 1;
}

/* Buttons */
.btn {
    margin: 0 1;
    min-width: 8;
    height: 3;
}

.btn:focus {
    border: tall $accent;
}

.btn:hover {
    text-style: bold;
}

.btn-primary {
    background: $primary;
    color: $text;
}

.btn-primary:hover {
    background: $primary-lighten-1;
}

.btn-danger {
    background: $error;
    color: $text;
}

.btn-danger:hover {
    background: $error-lighten-1;
}

.btn-secondary {
    background: $surface;
    border: tall $primary;
}

.btn-secondary:hover {
    background: $primary 20%;
}

/* Section Titles */
.section-title {
    text-style: bold;
    margin: 0 0 1 0;
    padding: 0 1;
    color: $primary;
    background: $primary 10%;
}

/* Maximized View */
.-maximized {
    height: 1fr;
}
