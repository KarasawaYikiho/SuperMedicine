/* SuperMedicine TUI Stylesheet */

Screen {
    layout: vertical;
}

#app-body {
    height: 1fr;
    width: 100%;
}

/* Sidebar */
#sidebar {
    width: 22;
    height: 100%;
    background: $surface;
    border-right: tall $primary;
}

#nav-list {
    height: 100%;
    background: $surface;
}

#nav-list > NavItem {
    padding: 0 2;
    height: 3;
}

#nav-list > NavItem:hover {
    background: $primary 20%;
}

#nav-list > NavItem.-active {
    background: $primary 40%;
    text-style: bold;
}

/* Main Area */
#main-area {
    width: 1fr;
    height: 100%;
    layout: vertical;
}

#view-title {
    height: 1;
    width: 100%;
    padding: 0 2;
    background: $primary 30%;
    text-style: bold;
    content-align: left middle;
}

#content-pane {
    height: 1fr;
    width: 100%;
    overflow-y: auto;
    padding: 1 2;
}

/* Input Bar */
#input-bar {
    height: 3;
    width: 100%;
    background: $surface;
    border-top: tall $primary;
    padding: 0 1;
}

#prompt-prefix {
    width: 3;
    height: 3;
    content-align: left middle;
    text-style: bold;
    color: $primary;
}

#prompt-input {
    width: 1fr;
    height: 3;
}

/* Status Bar */
#status-bar {
    height: 1;
    width: 100%;
    background: $surface;
    border-top: tall $primary;
}

#status-left {
    width: 1fr;
    content-align: left middle;
}

#status-center {
    width: 1fr;
    content-align: center middle;
}

#status-right {
    width: 1fr;
    content-align: right middle;
}

/* Chat View */
#chat-output {
    height: 1fr;
    width: 100%;
    overflow-y: auto;
    padding: 0 1;
}

/* Dashboard */
.dashboard-stat {
    height: 1fr;
    padding: 0 2;
}

/* Tables */
#workspace-table,
#paper-table,
#exp-table,
#tool-table,
#llm-table,
#dialog-table {
    height: 1fr;
}

#llm-status {
    height: auto;
    padding: 1 0;
}

#llm-secret-hint {
    color: $text-muted;
    padding: 0 0 1 0;
}

/* Buttons */
.btn {
    margin: 0 1;
    min-width: 10;
}

.btn-primary {
    background: $primary;
    color: $text;
}

.btn-primary:hover {
    background: $primary-lighten-1;
}

.btn-danger {
    background: $error;
    color: $text;
}

.btn-danger:hover {
    background: $error-lighten-1;
}

.btn-secondary {
    background: $surface;
    border: tall $primary;
}

.btn-secondary:hover {
    background: $primary 20%;
}

/* Section Titles */
.section-title {
    text-style: bold;
    margin: 1 0 1 0;
    color: $primary;
}

/* Maximized View */
.-maximized {
    height: 1fr;
}
