/* SuperMedicine TUI Stylesheet
   Variables ($primary, $surface, $background, etc.) are auto-generated
   by Textual from the Theme registered in the app module.
*/

Screen {
    layout: vertical;
    background: $background;
    color: $foreground;
}

Header {
    background: $primary;
    color: $foreground;
    text-style: bold;
    height: 1;
}

Footer {
    background: $surface;
    color: $text-muted;
    border-top: tall $primary 35%;
}

#app-body {
    height: 1fr;
    width: 100%;
    min-height: 8;
}

/* Sidebar */
#sidebar {
    width: 24;
    min-width: 20;
    height: 100%;
    background: $surface;
    border-right: tall $primary 60%;
}

#sidebar-title {
    height: 2;
    padding: 0 1;
    text-style: bold;
    color: $accent;
    content-align: center middle;
}

#sidebar-subtitle {
    height: 2;
    padding: 0 1;
    color: $text-muted;
    content-align: center middle;
    border-bottom: tall $primary 25%;
}

.shell-title {
    background: $primary 8%;
}

.shell-subtitle {
    text-style: italic;
}

#nav-list {
    height: 1fr;
    background: $surface;
}

#nav-list > NavItem {
    padding: 0 1;
    height: 2;
    color: $foreground;
}

#nav-list > NavItem:hover {
    background: $primary 18%;
}

#nav-list > NavItem.-active {
    background: $primary 35%;
    text-style: bold;
    border-left: heavy $accent;
    color: $foreground;
}

#tui-menu-panel {
    width: 42;
    height: auto;
    max-height: 85%;
    margin: 1 0 0 1;
    padding: 1 1;
    background: $surface;
    border: round $primary;
}

#tui-menu-title {
    height: 3;
    padding: 0 1;
    content-align: left middle;
}

.tui-menu-list {
    height: auto;
    max-height: 18;
    background: $surface;
}

.tui-menu-list > MenuOption {
    height: 2;
    padding: 0 1;
}

.tui-menu-list > MenuOption:hover,
.tui-menu-list > MenuOption.-active {
    background: $primary 35%;
    text-style: bold;
}

#sidebar-shortcuts {
    height: 4;
    padding: 0 1;
    color: $text-muted;
    border-top: tall $primary 35%;
    background: $primary 8%;
}

.shortcut-hint {
    color: $text-muted;
}

/* Main Area */
#main-area {
    width: 1fr;
    height: 100%;
    layout: vertical;
}

#view-title {
    height: 2;
    width: 100%;
    padding: 0 2;
    background: $surface;
    color: $foreground;
    text-style: bold;
    content-align: left middle;
    border-bottom: tall $primary 35%;
}

.view-heading {
    color: $accent;
}

#content-pane {
    height: 1fr;
    width: 100%;
    overflow-y: auto;
    padding: 1 1;
    background: $background;
}

/* Input Bar */
#input-bar {
    min-height: 3;
    height: auto;
    width: 100%;
    background: $surface;
    border-top: tall $primary 60%;
    padding: 0 1;
}

#prompt-prefix {
    width: 4;
    height: auto;
    content-align: center middle;
    text-style: bold;
    color: $accent;
}

#prompt-input {
    width: 1fr;
    height: auto;
    border: round $primary 35%;
    background: $background;
}

#prompt-input:focus {
    border: round $accent;
}

/* Status Bar */
#status-bar {
    height: 1;
    width: 100%;
    background: $surface;
    border-top: tall $primary 35%;
    color: $text-muted;
}

#status-left {
    width: 1fr;
    content-align: left middle;
}

#status-center {
    width: 1fr;
    content-align: center middle;
}

#status-right {
    width: 1fr;
    content-align: right middle;
}

/* Chat View */
#chat-output {
    height: 1fr;
    width: 100%;
    overflow-y: auto;
    padding: 0 1;
    border: round $primary 30%;
    background: $surface;
}

#chat-output:focus {
    border: round $accent;
}

/* Dashboard */
.dashboard-stat {
    height: 1fr;
    min-height: 5;
    padding: 0 2;
}

#dashboard-summary {
    height: auto;
    padding: 0 2 1 2;
    color: $text-muted;
}

#dashboard-advice {
    height: auto;
    padding: 1 2;
    border: round $primary 40%;
    background: $primary 10%;
}

/* Tables */
#workspace-table,
#dashboard-table,
#paper-table,
#exp-table,
#tool-table,
#llm-table,
#dialog-table,
#log-table {
    height: 1fr;
    min-height: 5;
    border: round $primary 30%;
}

#log-table {
    min-height: 8;
}

DataTable:focus {
    border: round $accent;
}

Input,
Select {
    height: auto;
    min-width: 12;
}

.form-row {
    height: auto;
    min-height: 3;
    margin: 0 0 1 0;
}

#llm-status {
    height: auto;
    padding: 1 0;
}

#workspace-status,
#paper-status,
#exp-status,
#tool-status,
#llm-status,
#dialog-status,
#log-status,
#log-detail {
    height: auto;
    min-height: 1;
    padding: 0 1;
    color: $text-muted;
    border-left: tall $primary 40%;
    background: $surface;
}

#log-detail {
    max-height: 12;
    overflow-y: auto;
    border: round $primary 35%;
    margin: 1 0 0 0;
}

.status-info {
    color: $text-muted;
    border-left: tall $primary;
}

.status-success {
    color: $success;
    border-left: tall $success;
}

.status-warning {
    color: $warning;
    border-left: tall $warning;
}

.status-error {
    color: $error;
    border-left: tall $error;
    text-style: bold;
}

#llm-secret-hint {
    color: $text-muted;
    padding: 0 0 1 0;
}

#llm-current {
    height: auto;
    padding: 0 1 1 1;
    color: $accent;
}

#llm-form {
    height: auto;
    border: round $primary 30%;
    padding: 1;
}

/* Buttons */
.btn {
    margin: 0 1;
    min-width: 8;
    height: 3;
}

.btn:focus {
    border: tall $accent;
}

.btn:hover {
    text-style: bold;
}

.btn-primary {
    background: $primary;
    color: $foreground;
}

.btn-primary:hover {
    background: $primary-lighten-1;
}

.btn-danger {
    background: $error;
    color: $foreground;
}

.btn-danger:hover {
    background: $error-lighten-1;
}

.btn-secondary {
    background: $surface;
    border: tall $primary;
}

.btn-secondary:hover {
    background: $primary 20%;
}

/* Section Titles */
.section-title {
    text-style: bold;
    margin: 0 0 1 0;
    padding: 0 1;
    color: $primary;
    background: $primary 10%;
}

/* Maximized View */
.-maximized {
    height: 1fr;
    border: heavy $accent;
    background: $background;
}
